<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required so live weather/routing fetches work in RELEASE builds.
         (debug/profile manifests declare INTERNET separately and merge it
         into those variants; release uses only this main manifest.) -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Foreground-only location: shows HER live position dot on the snow map
         while driving. NO ACCESS_BACKGROUND_LOCATION by design (the app is
         foreground-only; background tracking would be a dignity over-reach). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- WS5 actuator channel: WAKE_LOCK holds the screen on so a driver
         glancing at a live hazard never finds a dark screen (wakelock_plus). -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Foreground-service perms REMOVED 2026-07-10 (W3 OPS-062 entry gate):
         they were DECLARED ONLY — no Service exists — and a manifest that
         requests location-class capabilities it does not use is a false
         claim to both the store review and the privacy page. When the
         explicit, user-visible, driver-initiated ongoing-drive Service is
         actually built, FOREGROUND_SERVICE + FOREGROUND_SERVICE_LOCATION
         return in the same change-set — and we STILL withhold
         ACCESS_BACKGROUND_LOCATION: no silent, notification-less background
         location (dignity boundary, unchanged). -->
    <application
        android:label="SNGNav"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- flutter_tts package-visibility requirement (Android 11+ /
             targetSdk >= 30): without this, the engine cannot see the
             system TTS service and speak() fails SILENTLY — the ja voice
             channel HER relies on dies with no error surfaced (our speak
             call is inside a catch). Mandated by the flutter_tts README. -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE"/>
        </intent>
    </queries>
</manifest>
